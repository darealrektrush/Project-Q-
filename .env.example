# --- Server ---
PORT=3000

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Secret string set via setWebhook(secret_token=...); must match x-telegram-bot-api-secret-token header
TELEGRAM_WEBHOOK_SECRET=
# The forum supergroup's chat id (negative number, e.g. -1001234567890)
TELEGRAM_CHAT_ID=
# Allowlist of forum topics as name:message_thread_id pairs
TELEGRAM_TOPIC_IDS=fawkq-chat:111,fawkq-announcements:222

# --- fawkq.com website webhook ---
BAGWORK_SECRET=
FAWKQ_WEBSITE_URL=https://fawkq.com
# XP awarded per 1 SOL of bagwork reward
XP_PER_SOL=1000

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Solana / Helius ---
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
TOKEN_MINT=

# --- Wallets ---
# Isolated hot wallet that receives creator rewards; signs Stage 1. Base58 secret key.
CREATOR_WALLET_SECRET=
CREATOR_WALLET_PUBLIC=
# Plain hot wallet (NOT a Squads multisig) that signs Stage 2 automatically. Base58 secret key.
COMMUNITY_WALLET_SECRET=
COMMUNITY_WALLET_PUBLIC=
# Never comingled with other funds
DEV_WALLET_PUBLIC=
# Can be a Squads multisig, only ever receives funds
OCEAN_WALLET_PUBLIC=
BAG_WALLET_PUBLIC=
# Parked for manual pump.fun buys, not automated
BUYBACK_RESERVE_WALLET_PUBLIC=

# Lamports left in the creator wallet as a fee buffer, not distributed
DISTRIBUTION_RESERVE_LAMPORTS=5000000
